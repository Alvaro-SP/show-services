---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

// Carga datos del CMS
const general = await getEntry('site', 'general');
const servicios = (await getCollection('servicios')).sort(
  (a, b) => (a.data.orden ?? 0) - (b.data.orden ?? 0)
);
const eventos = await getCollection('eventos');
const testimonios = await getCollection('testimonios');
const faqs = (await getCollection('faq')).sort(
  (a, b) => (a.data.orden ?? 0) - (b.data.orden ?? 0)
);

const g = general!.data;
const waUrl = `https://wa.me/${g.whatsapp}?text=${encodeURIComponent(g.mensajeWhatsapp)}`;

const redes = [
  { url: g.instagram, label: 'Instagram', icon: 'IG' },
  { url: g.tiktok, label: 'TikTok', icon: 'TT' },
  { url: g.facebook, label: 'Facebook', icon: 'FB' },
].filter(r => r.url);
---

<Layout title={`${g.nombre} — ${g.tagline}`} description={g.descripcion} whatsapp={g.whatsapp}>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="wrap hero-wrap">
      <div class="hero-text">
        <div class="kicker pop-in" style="animation-delay: 0.05s">
          <span class="dot"></span> Show sano · Guatemala
        </div>
        <h1 class="hero-title pop-in" style="animation-delay: 0.15s">
          <span class="line line-1">{g.nombre.split(' ')[0]}</span>
          <span class="line line-2">{g.nombre.split(' ').slice(1).join(' ')}</span>
        </h1>
        <p class="hero-tag pop-in" style="animation-delay: 0.3s">{g.tagline}</p>
        {g.descripcion && (
          <p class="hero-desc pop-in" style="animation-delay: 0.45s">{g.descripcion}</p>
        )}
        <div class="hero-cta pop-in" style="animation-delay: 0.6s">
          <a href={waUrl} class="btn-wa" target="_blank" rel="noopener">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.5 14.4l-2.5-1.3c-.3-.1-.6-.1-.8.1l-1.1 1.4c-1.7-.9-3-2.2-3.9-3.9l1.4-1.1c.2-.2.3-.5.1-.8L9.4 6.3c-.2-.3-.5-.4-.8-.3L6.3 6.7c-.3.1-.5.4-.5.7 0 5.6 4.6 10.2 10.2 10.2.3 0 .6-.2.7-.5l.7-2.3c.1-.3 0-.6-.3-.8z"/>
            </svg>
            Cotizar por WhatsApp
          </a>
        </div>
      </div>

      <div class="hero-visual">
        {g.heroImage ? (
          <img src={g.heroImage} alt={g.nombre} class="hero-img" />
        ) : (
          <div class="hero-placeholder">
            <div class="emoji emoji-1">🎈</div>
            <div class="emoji emoji-2">🎪</div>
            <div class="emoji emoji-3">🎂</div>
            <div class="emoji emoji-4">🤡</div>
          </div>
        )}
        <!-- "Sello" decorativo -->
        <div class="seal">
          <svg viewBox="0 0 100 100" width="120" height="120">
            <defs>
              <path id="circle" d="M 50, 50 m -38, 0 a 38,38 0 1,1 76,0 a 38,38 0 1,1 -76,0" />
            </defs>
            <text font-family="Bagel Fat One" font-size="11" fill="#1A1A2E">
              <textPath href="#circle">RISAS GARANTIZADAS · DIVERSIÓN ASEGURADA · </textPath>
            </text>
            <text x="50" y="55" text-anchor="middle" font-size="22" font-family="Bagel Fat One" fill="#E63946">¡YA!</text>
          </svg>
        </div>
      </div>
    </div>

    <!-- Banda decorativa con texto repetido -->
    <div class="banda">
      <div class="banda-track">
        {Array(8).fill(0).map(() => (
          <span>RISAS · SHOW SANO · DIVERSIÓN · GLOBOFLEXIA · ANIMACIÓN · </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICIOS ===== -->
  <section class="seccion servicios" id="servicios">
    <div class="wrap">
      <div class="sec-header">
        <span class="num">01</span>
        <h2>Lo que <em>hacemos</em></h2>
      </div>

      <div class="grid-servicios">
        {servicios.map((s, i) => (
          <article class="card-servicio" style={`--i: ${i}`}>
            <div class="icono">{s.data.icono}</div>
            <h3>{s.data.titulo}</h3>
            <p>{s.data.descripcion}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== GALERÍA ===== -->
  {eventos.length > 0 && (
    <section class="seccion galeria" id="galeria">
      <div class="wrap">
        <div class="sec-header">
          <span class="num">02</span>
          <h2>Eventos <em>recientes</em></h2>
        </div>

        <div class="grid-galeria">
          {eventos.map((e, i) => (
            <figure class="evento" style={`--rot: ${(i % 3 - 1) * 1.5}deg`}>
              <img src={e.data.imagen} alt={e.data.titulo} loading="lazy" />
              <figcaption>
                <strong>{e.data.titulo}</strong>
                {e.data.descripcion && <span>{e.data.descripcion}</span>}
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== TESTIMONIOS ===== -->
  {testimonios.length > 0 && (
    <section class="seccion testimonios" id="testimonios">
      <div class="wrap">
        <div class="sec-header">
          <span class="num">03</span>
          <h2>Lo que <em>dicen</em></h2>
        </div>

        <div class="grid-testi">
          {testimonios.map((t) => (
            <blockquote class="testi">
              <p>"{t.data.texto}"</p>
              <cite>
                <strong>{t.data.nombre}</strong>
                {t.data.evento && <span> · {t.data.evento}</span>}
              </cite>
            </blockquote>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== FAQ ===== -->
  {faqs.length > 0 && (
    <section class="seccion faq" id="faq">
      <div class="wrap wrap-narrow">
        <div class="sec-header">
          <span class="num">04</span>
          <h2>Preguntas <em>frecuentes</em></h2>
        </div>

        <div class="lista-faq">
          {faqs.map((f) => (
            <details>
              <summary>{f.data.pregunta}</summary>
              <p>{f.data.respuesta}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== CTA FINAL ===== -->
  <section class="cta-final">
    <div class="wrap">
      <h2>¿Listos para reírse?</h2>
      <p>Cotizá tu evento por WhatsApp. Te respondemos rápido y con cariño.</p>
      <a href={waUrl} class="btn-wa" target="_blank" rel="noopener">
        Escribir por WhatsApp
      </a>
      {redes.length > 0 && (
        <div class="redes">
          {redes.map((r) => (
            <a href={r.url} target="_blank" rel="noopener" aria-label={r.label}>{r.icon}</a>
          ))}
        </div>
      )}
    </div>
  </section>

  <footer>
    <div class="wrap">
      <p>© {new Date().getFullYear()} {g.nombre} · Hecho con cariño en Guatemala 🇬🇹</p>
      <p class="admin-link"><a href="/admin/">Panel</a></p>
    </div>
  </footer>

  <!-- Botón flotante WhatsApp -->
  <a href={waUrl} class="wa-float" target="_blank" rel="noopener" aria-label="WhatsApp">
    <svg viewBox="0 0 24 24"><path d="M20.52 3.48A11.78 11.78 0 0 0 12.02 0C5.51 0 .22 5.29.22 11.8c0 2.08.54 4.11 1.58 5.9L0 24l6.45-1.7a11.78 11.78 0 0 0 5.57 1.42h.01c6.5 0 11.79-5.29 11.79-11.8 0-3.15-1.23-6.11-3.3-8.34zm-8.5 18.16h-.01a9.8 9.8 0 0 1-4.99-1.37l-.36-.21-3.7.97.99-3.6-.24-.37a9.78 9.78 0 0 1-1.5-5.26c0-5.41 4.4-9.81 9.81-9.81 2.62 0 5.08 1.02 6.93 2.87a9.74 9.74 0 0 1 2.88 6.94c0 5.41-4.4 9.81-9.81 9.81zm5.38-7.34c-.3-.15-1.74-.86-2.01-.95-.27-.1-.47-.15-.66.15-.2.3-.76.95-.93 1.15-.17.2-.34.22-.64.07-.3-.15-1.24-.46-2.37-1.46-.87-.78-1.46-1.74-1.64-2.04-.17-.3-.02-.46.13-.6.13-.13.3-.34.45-.51.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.66-1.6-.91-2.18-.24-.57-.49-.49-.66-.5-.17-.01-.37-.01-.57-.01-.2 0-.52.07-.79.37-.27.3-1.04 1.01-1.04 2.47s1.06 2.87 1.21 3.07c.15.2 2.1 3.2 5.07 4.49.71.3 1.26.49 1.69.62.71.22 1.36.19 1.87.12.57-.09 1.74-.71 1.99-1.4.25-.69.25-1.28.17-1.4-.07-.12-.27-.2-.57-.34z"/></svg>
  </a>
</Layout>

<style>
  /* ===== HERO ===== */
  .hero {
    padding: 5rem 0 0;
    position: relative;
    overflow: hidden;
  }

  .hero-wrap {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
    align-items: center;
    min-height: 70vh;
  }

  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rojo);
    margin-bottom: 1.5rem;
  }
  .dot {
    width: 8px;
    height: 8px;
    background: var(--rojo);
    border-radius: 50%;
    animation: pulse 1.5s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }

  .hero-title {
    font-size: clamp(3.5rem, 12vw, 9rem);
    line-height: 0.85;
    margin-bottom: 1.5rem;
  }
  .hero-title .line {
    display: block;
  }
  .hero-title .line-1 {
    color: var(--tinta);
  }
  .hero-title .line-2 {
    color: var(--rojo);
    transform: translateX(0.8em);
    font-style: italic;
  }

  .hero-tag {
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--tinta);
  }
  .hero-desc {
    font-size: 1.05rem;
    max-width: 480px;
    margin-bottom: 2rem;
    color: var(--tinta-2);
  }

  .hero-visual {
    position: relative;
    min-height: 400px;
  }
  .hero-img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    border-radius: 30px;
    border: 4px solid var(--tinta);
    box-shadow: 12px 12px 0 var(--amarillo);
    transform: rotate(2deg);
  }
  .hero-placeholder {
    aspect-ratio: 4/5;
    background: linear-gradient(135deg, var(--amarillo), var(--rojo));
    border: 4px solid var(--tinta);
    border-radius: 30px;
    box-shadow: 12px 12px 0 var(--azul);
    transform: rotate(2deg);
    position: relative;
    overflow: hidden;
  }
  .emoji {
    position: absolute;
    font-size: 4rem;
    animation: float 4s ease-in-out infinite;
  }
  .emoji-1 { top: 10%; left: 15%; animation-delay: 0s; }
  .emoji-2 { top: 20%; right: 15%; animation-delay: 0.7s; font-size: 5rem; }
  .emoji-3 { bottom: 25%; left: 20%; animation-delay: 1.4s; font-size: 4.5rem; }
  .emoji-4 { bottom: 10%; right: 18%; animation-delay: 2.1s; font-size: 5.5rem; }
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(-5deg); }
    50% { transform: translateY(-15px) rotate(5deg); }
  }

  .seal {
    position: absolute;
    bottom: -30px;
    left: -30px;
    background: var(--crema);
    border-radius: 50%;
    padding: 8px;
    border: 3px solid var(--tinta);
    box-shadow: 4px 4px 0 var(--tinta);
    animation: spin 18s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Banda animada */
  .banda {
    margin-top: 4rem;
    background: var(--tinta);
    color: var(--amarillo);
    padding: 1rem 0;
    overflow: hidden;
    transform: rotate(-2deg);
    border-top: 3px solid var(--tinta);
    border-bottom: 3px solid var(--tinta);
  }
  .banda-track {
    display: flex;
    white-space: nowrap;
    font-family: var(--display);
    font-size: 1.3rem;
    animation: marquee 30s linear infinite;
  }
  .banda-track span {
    padding: 0 1rem;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ===== SECCIONES ===== */
  .seccion {
    padding: 6rem 0;
    position: relative;
  }
  .wrap-narrow {
    max-width: 760px;
  }
  .sec-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 3rem;
  }
  .sec-header .num {
    font-family: var(--display);
    font-size: 1.5rem;
    color: var(--rojo);
  }
  .sec-header h2 em {
    color: var(--rojo);
    font-style: italic;
  }

  /* Servicios */
  .grid-servicios {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .card-servicio {
    background: white;
    padding: 2rem;
    border-radius: 20px;
    border: 3px solid var(--tinta);
    box-shadow: 6px 6px 0 var(--tinta);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .card-servicio:nth-child(odd) {
    background: var(--amarillo);
  }
  .card-servicio:nth-child(3n) {
    background: var(--azul);
    color: white;
  }
  .card-servicio:hover {
    transform: translate(-3px, -3px);
    box-shadow: 9px 9px 0 var(--tinta);
  }
  .card-servicio .icono {
    font-size: 3rem;
    margin-bottom: 1rem;
  }
  .card-servicio h3 {
    margin-bottom: 0.5rem;
  }

  /* Galería */
  .grid-galeria {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 2rem;
  }
  .evento {
    transform: rotate(var(--rot, 0deg));
    transition: transform 0.3s ease;
  }
  .evento:hover {
    transform: rotate(0) scale(1.03);
  }
  .evento img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    border-radius: 12px;
    border: 3px solid var(--tinta);
    box-shadow: 5px 5px 0 var(--rojo);
  }
  .evento figcaption {
    text-align: center;
    margin-top: 0.8rem;
    font-size: 0.95rem;
  }
  .evento figcaption strong {
    display: block;
    font-family: var(--display);
    font-size: 1.1rem;
  }

  /* Testimonios */
  .testimonios {
    background: var(--crema-2);
  }
  .grid-testi {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .testi {
    background: white;
    padding: 2rem;
    border-radius: 20px;
    border: 3px solid var(--tinta);
    box-shadow: 5px 5px 0 var(--amarillo);
    position: relative;
  }
  .testi::before {
    content: "“";
    position: absolute;
    top: -20px;
    left: 20px;
    font-family: var(--display);
    font-size: 5rem;
    color: var(--rojo);
    line-height: 1;
  }
  .testi p {
    font-style: italic;
    margin-bottom: 1rem;
  }
  .testi cite {
    font-style: normal;
    font-size: 0.95rem;
    color: var(--tinta-2);
  }
  .testi cite strong {
    color: var(--tinta);
  }

  /* FAQ */
  .lista-faq details {
    background: white;
    border: 3px solid var(--tinta);
    border-radius: 14px;
    padding: 1rem 1.5rem;
    margin-bottom: 0.8rem;
    transition: box-shadow 0.2s;
  }
  .lista-faq details[open] {
    box-shadow: 4px 4px 0 var(--rojo);
  }
  .lista-faq summary {
    font-weight: 700;
    cursor: pointer;
    font-size: 1.1rem;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .lista-faq summary::-webkit-details-marker { display: none; }
  .lista-faq summary::after {
    content: "+";
    font-family: var(--display);
    font-size: 1.8rem;
    color: var(--rojo);
    transition: transform 0.2s;
  }
  .lista-faq details[open] summary::after {
    transform: rotate(45deg);
  }
  .lista-faq p {
    margin-top: 1rem;
    color: var(--tinta-2);
  }

  /* CTA final */
  .cta-final {
    background: var(--rojo);
    color: white;
    padding: 5rem 0;
    text-align: center;
    position: relative;
    border-top: 4px solid var(--tinta);
    border-bottom: 4px solid var(--tinta);
  }
  .cta-final h2 {
    color: var(--amarillo);
    margin-bottom: 1rem;
  }
  .cta-final p {
    font-size: 1.15rem;
    margin-bottom: 2rem;
    opacity: 0.95;
  }
  .cta-final .btn-wa {
    background: var(--amarillo);
    color: var(--tinta);
    border-color: var(--tinta);
  }
  .redes {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    margin-top: 2rem;
  }
  .redes a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--amarillo);
    color: var(--tinta);
    border-radius: 50%;
    border: 2px solid var(--tinta);
    font-family: var(--display);
    font-size: 0.85rem;
    transition: transform 0.2s;
  }
  .redes a:hover {
    transform: translateY(-3px);
  }

  /* Footer */
  footer {
    background: var(--tinta);
    color: var(--crema);
    padding: 2rem 0;
    text-align: center;
    font-size: 0.9rem;
  }
  .admin-link a {
    opacity: 0.5;
    font-size: 0.8rem;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 880px) {
    .hero {
      padding-top: 3rem;
    }
    .hero-wrap {
      grid-template-columns: 1fr;
      gap: 2rem;
      min-height: auto;
    }
    .hero-title .line-2 {
      transform: translateX(0.4em);
    }
    .seccion {
      padding: 4rem 0;
    }
    .seal {
      width: 100px;
      height: 100px;
      bottom: -20px;
      left: -10px;
    }
    .wa-float {
      width: 56px;
      height: 56px;
      bottom: 1rem;
      right: 1rem;
    }
  }
</style>
